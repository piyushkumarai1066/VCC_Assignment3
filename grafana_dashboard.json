
{
  "dashboard": {
    "title": "GCP Auto-Scaling Monitoring",
    "panels": [
      {
        "type": "graph",
        "title": "CPU Utilization",
        "targets": [
          {
            "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)",
            "legendFormat": "{{instance}}",
            "refId": "A"
          }
        ]
      }
    ]
  }
}
  